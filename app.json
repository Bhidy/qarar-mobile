{
  "expo": {
    "name": "Smart Signals",
    "slug": "rumble-pro",
    "version": "1.0.1",
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/8d61ac43-8ae4-4fe3-a101-558817aabe3e",
      "enabled": true,
      "checkAutomatically": "ON_ERROR_RECOVERY",
      "fallbackToCacheTimeout": 0,
      "useEmbeddedUpdate": true,
      "requestHeaders": {
        "expo-channel-name": "production"
      }
    },
    "orientation": "default",
    "icon": "./assets/icon.png",
    "scheme": "rumblepro",
    "newArchEnabled": true,
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#0A0E1F",
    "splash": {
      "backgroundColor": "#0A0E1F"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rumble.pro",
      "buildNumber": "96",
      "appleTeamId": "7F4FTZQ5H7",
      "infoPlist": {
        "UIStatusBarStyle": "UIStatusBarStyleLightContent",
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Smart Signals uses the camera only when you choose to take a new profile photo.",
        "NSPhotoLibraryUsageDescription": "Smart Signals accesses your photo library only when you choose a profile picture.",
        "NSFaceIDUsageDescription": "Smart Signals uses Face ID to securely unlock your account on this device."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0E1F"
      },
      "package": "com.rumble.pro",
      "versionCode": 17,
      "googleServicesFile": "./google-services.json",
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ]
    },
    "androidNavigationBar": {
      "backgroundColor": "#0A0E1F"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Smart Signals accesses your photo library only when you choose a profile picture.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      [
        "expo-system-ui",
        {
          "style": "dark"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#4D8EF8",
          "iosDisplayInForeground": true,
          "sounds": []
        }
      ],
      "expo-status-bar",
      "expo-splash-screen",
      "./plugins/with-fast-android.js",
      "./plugins/with-android-gradle-memory.js",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.4",
            "buildReactNativeFromSource": true
          }
        }
      ],
      "expo-web-browser",
      "expo-image",
      "expo-updates"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "8d61ac43-8ae4-4fe3-a101-558817aabe3e"
      }
    }
  }
}
