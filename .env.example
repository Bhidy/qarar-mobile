# Smart Signals — mobile environment template
# Copy to `.env` and fill in real values. `.env` is gitignored; never commit secrets.
# All keys are EXPO_PUBLIC_* and are bundled into the client — use only client-safe values.

# Supabase (project: smart-signals)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key   # anon role only — NEVER the service_role key

# Expo Push Notifications
EXPO_PUBLIC_PROJECT_ID=your-eas-project-id

# Google Sign-In — Web OAuth client id of the Google Cloud project.
# Used as the idToken audience that Supabase Auth verifies on signInWithIdToken.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
